# ---- Required ----
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ---- Optional: Grok/xAI setup generation (falls back to a local generator if unset) ----
GROK_API_KEY=
GROK_MODEL=grok-4

# ---- Storage (point DB at your Zeabur persistent volume) ----
HL_INTEL_DB_PATH=/data/hl_intel.db
HL_INTEL_WATCHLIST_PATH=/app/watchlist.json
RETENTION_DAYS=14

# ---- Scan cadence ----
WALLET_SCAN_INTERVAL_SECONDS=180
COIN_SCAN_INTERVAL_SECONDS=300

# ---- Coin scanner / setups ----
ACCOUNT_EQUITY=5000
RISK_PCT=0.01
MIN_SCORE_FOR_ALERT=52
ENABLE_CHARTS=false
SEND_STARTUP_MESSAGE=false
IDLE_WHEN_OFF=true

# ---- Wallet thresholds ----
WHALE_POSITION_THRESHOLD_USD=500000
FUNDING_RATE_SPIKE_THRESHOLD=0.0001
OI_SURGE_PCT_THRESHOLD=15
MIN_OI_FOR_SURGE=50000000
LIQ_PROXIMITY_THRESHOLD_PCT=10
LIQ_PROXIMITY_DANGER_PCT=5
MIN_NOTIONAL_FOR_LIQ_ALERT=5000000

# ---- Correlation (wallet x technical) ----
CORRELATION_MIN_SCORE=60
CORRELATION_MIN_WHALES=2
CORRELATION_COOLDOWN_MINUTES=180

# ---- Hyperliquid client pacing ----
HL_INFO_MIN_REQUEST_INTERVAL_SECONDS=0.75
HL_INFO_MAX_RETRIES=5
HL_HTTP_TIMEOUT_SECONDS=20

# ---- Pay-to-activate (Solana USDC) ----
# Every /start re-charges; value commands need an active paid window.
# First /scan per chat is free. $3 flat for up to 3 days = ~$1/day.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# REQUIRED: your Solana USDC receiving address. Leave blank here; set it in the
# environment. The app refuses to start with no payout address.
PAYMENT_RECEIVING_ADDRESS=
PAYMENT_PRICE_USD=3.00
PAYMENT_VALIDITY_DAYS=3
# Operator's Telegram chat id — bypasses the paywall (0 = disabled).
OWNER_CHAT_ID=0
